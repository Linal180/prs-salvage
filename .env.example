# Copy to apps/api/.env
DATABASE_URL="postgresql://prs:prs_dev_password@localhost:5433/prs?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000
WEB_ORIGIN="http://localhost:5173"
